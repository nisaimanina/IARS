@model IEnumerable<IARS.Models.KaizenProposal>

@{
    Layout = null;
    ViewData["Title"] = "Approver Dashboard";
    var userName  = Context.Session.GetString("UserName") ?? "User";
    var role      = (Context.Session.GetString("UserRole") ?? "Approver").ToUpper();
    var initial   = userName.Length > 0 ? userName[0].ToString().ToUpper() : "A";
    var pending   = Model?.ToList() ?? new List<IARS.Models.KaizenProposal>();
    var myHistory = ViewBag.MyHistory as List<IARS.Models.KaizenProposal> ?? new List<IARS.Models.KaizenProposal>();
    var roleLabel = role switch {
        "KAIZENCOMMITTEE" => "Kaizen Committee",
        "HOD"             => "Reviewer",
        "APPROVER"        => "Approver",
        "REVIEWER"        => "Reviewer",
        "ADMIN"           => "Administrator",
        _                 => "Employee"
    };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Approver Dashboard — IARS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
        :root{--red:#ED1C24;--dark:#0e1118;--tx:#1a1d2e;--muted:#7c8db5;--bg:#f4f6fa;--border:#e4e9f4;}
        body{font-family:'Inter',sans-serif;background:var(--bg);overflow:hidden;height:100vh;display:flex;}
        #sb{width:300px;min-height:100vh;background:var(--dark);display:flex;flex-direction:column;flex-shrink:0;transition:all .3s;position:relative;z-index:100;}
        #sb.collapsed{width:80px;}
        #sbToggle{position:absolute;top:35px;right:-16px;width:32px;height:32px;background:var(--red);border:none;border-radius:50%;color:white;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:200;box-shadow:0 4px 14px rgba(237,28,36,.4);}
        .sb-brand{display:flex;flex-direction:column;align-items:center;padding:32px 18px 24px;border-bottom:1px solid rgba(255,255,255,.05);text-decoration:none;overflow:hidden;}
        .logo-box{background:white;border-radius:14px;padding:12px 16px;width:100%;max-width:180px;box-shadow:0 6px 16px rgba(0,0,0,.25);display:flex;align-items:center;justify-content:center;}
        .logo-box img{width:100%;max-width:150px;height:auto;object-fit:contain;}
        .brand-label{margin-top:14px;text-align:center;}
        .brand-label .bn { color:white; font-weight:900; font-size:1.15rem; letter-spacing:-0.2px; white-space:nowrap; }
        .brand-label .bt{color:rgba(255,255,255,.32);font-size:.75rem;letter-spacing:1px;text-transform:uppercase;margin-top:4px;white-space:nowrap;}
        #sb.collapsed .sb-brand{display:none;}
        .sb-sec{padding:24px 22px 8px;font-size:.72rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:rgba(255,255,255,.2);white-space:nowrap;}
        #sb.collapsed .sb-sec{opacity:0;height:28px;padding:0;}
        .sb-nav{list-style:none;padding:4px 12px;flex-grow:1;}
        .sb-nav a{display:flex;align-items:center;gap:16px;padding:12px 16px;color:rgba(255,255,255,.48);text-decoration:none;border-radius:12px;margin-bottom:6px;transition:all .3s;white-space:nowrap;overflow:hidden;font-size:1.05rem;font-weight:600;}
        .sb-nav a:hover{background:rgba(255,255,255,.07);color:rgba(255,255,255,.88);}
        .sb-nav a.on{background:var(--red);color:white;}
        .sb-nav a i{font-size:1.3rem;flex-shrink:0;width:24px;text-align:center;}
        .sb-nav .lbl{overflow:hidden;white-space:nowrap;}
        #sb.collapsed .sb-nav .lbl{display:none;}
        .sb-foot{padding:14px 12px;border-top:1px solid rgba(255,255,255,.05);}
        .sb-foot a{display:flex;align-items:center;gap:16px;padding:12px 16px;border-radius:12px;color:rgba(255,255,255,.38);text-decoration:none;font-size:1.05rem;font-weight:600;transition:all .3s;white-space:nowrap;overflow:hidden;}
        .sb-foot a:hover{background:rgba(237,28,36,.14);color:var(--red);}
        .sb-foot a i{font-size:1.3rem;flex-shrink:0;width:24px;text-align:center;}
        #sb.collapsed .sb-foot .lbl{display:none;}
        #main{flex-grow:1;display:flex;flex-direction:column;overflow:hidden;}
        .topbar{height:100px;background:white;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;padding:0 36px;flex-shrink:0;}
        .tb-left{display:flex;flex-direction:column;justify-content:center;}
        .tb-left .sysname{font-size:0.75rem;color:var(--red);font-weight:800;letter-spacing:0.8px;margin:0 0 4px 0;text-transform:uppercase;}
        .tb-left .ptitle{font-size:1.55rem;font-weight:900;color:var(--tx);letter-spacing:-0.4px;margin:0;}
        .tb-right{display:flex;align-items:center;justify-content:flex-end;gap:16px;}
        .user-chip{display:flex;align-items:center;gap:14px;background:#f7f8fc;border:1.5px solid var(--border);border-radius:14px;padding:6px 18px 6px 8px;}
        .u-avatar{width:46px;height:46px;background:#2563eb;color:white;border-radius:12px;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:1.15rem; letter-spacing:-0.5px; flex-shrink:0;}
        .u-info { text-align:left; }
        .u-info .uname { font-weight:800; font-size:1rem; color:var(--tx); line-height:1.2; }
        .u-info .urole { font-size:0.8rem; color:var(--muted); font-weight:600; }
        .ca{flex-grow:1;overflow-y:auto;padding:32px 36px;}
        .stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:32px;}
        .stat-card{background:white;border-radius:16px;border:1px solid var(--border);padding:22px 24px;display:flex;align-items:center;gap:16px;transition:transform .2s,box-shadow .2s;}
        .stat-card:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.06);}
        .sc-icon{width:54px;height:54px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;flex-shrink:0;}
        .sc-val{font-size:2rem;font-weight:900;color:var(--tx);line-height:1;}
        .sc-lbl{font-size:.78rem;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.8px;margin-top:4px;}
        .section-title{font-size:1.1rem;font-weight:900;color:var(--tx);margin-bottom:16px;display:flex;align-items:center;gap:10px;}
        .proposal-card{background:white;border-radius:16px;border:1px solid var(--border);padding:22px 26px;margin-bottom:14px;transition:box-shadow .2s;}
        .proposal-card:hover{box-shadow:0 6px 20px rgba(0,0,0,.06);}
        .pc-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;}
        .pc-title{font-size:1.05rem;font-weight:800;color:var(--tx);margin:0 0 4px;}
        .pc-meta{font-size:.82rem;color:var(--muted);font-weight:600;}
        .badge-status{display:inline-flex;align-items:center;gap:6px;border-radius:20px;padding:5px 14px;font-size:.75rem;font-weight:800;text-transform:uppercase;letter-spacing:.5px;}
        .bs-hodok{background:#eff6ff;color:#2563eb;border:1.5px solid #bfdbfe;}
        .bs-approved{background:#ecfdf5;color:#059669;border:1.5px solid #a7f3d0;}
        .bs-rejected{background:#fff1f2;color:#e11d48;border:1.5px solid #fecdd3;}
        .action-row{display:flex;gap:10px;margin-top:14px;padding-top:14px;border-top:1px solid var(--border);flex-wrap:wrap;}
        .btn-approve{background:#ecfdf5;color:#059669;border:1.5px solid #a7f3d0;border-radius:10px;padding:10px 20px;font-size:.88rem;font-weight:800;cursor:pointer;display:flex;align-items:center;gap:8px;font-family:inherit;transition:all .2s;}
        .btn-approve:hover{background:#d1fae5;}
        .btn-reject{background:#fff1f2;color:#e11d48;border:1.5px solid #fecdd3;border-radius:10px;padding:10px 20px;font-size:.88rem;font-weight:800;cursor:pointer;display:flex;align-items:center;gap:8px;font-family:inherit;transition:all .2s;}
        .btn-reject:hover{background:#ffe4e6;}
        .btn-view-sm{background:#eff6ff;color:#2563eb;border:1.5px solid #bfdbfe;border-radius:10px;padding:10px 18px;font-size:.88rem;font-weight:700;text-decoration:none;display:flex;align-items:center;gap:8px;transition:all .2s;}
        .btn-view-sm:hover{background:#dbeafe;}
        .remarks-area{width:100%;border:1.5px solid #e0e6f0;border-radius:10px;padding:10px 14px;font-family:inherit;font-size:.88rem;color:var(--tx);resize:none;margin-top:12px;}
        .hod-chip{display:inline-flex;align-items:center;gap:6px;background:#eff6ff;color:#2563eb;border-radius:10px;padding:4px 12px;font-size:.8rem;font-weight:700;margin-top:8px;}
        .toast-msg{position:fixed;top:24px;right:24px;z-index:9999;min-width:320px;border-radius:14px;padding:16px 22px;font-weight:700;font-size:.95rem;display:flex;align-items:center;gap:12px;box-shadow:0 8px 30px rgba(0,0,0,.12);animation:slideIn .3s ease;}
        @@keyframes slideIn{from{opacity:0;transform:translateX(30px)}to{opacity:1;transform:translateX(0)}}
        .empty-card{text-align:center;padding:60px 20px;background:white;border-radius:16px;border:1px solid var(--border);}
        ::-webkit-scrollbar{width:6px;}
        ::-webkit-scrollbar-thumb{background:#cfd6e4;border-radius:10px;}
    </style>
</head>
<body>

@if (TempData["Success"] != null)
{
    <div class="toast-msg" style="background:#ecfdf5;color:#059669;border:1.5px solid #a7f3d0;" id="toastMsg">
        <i class="bi bi-check-circle-fill" style="font-size:1.3rem;"></i> @TempData["Success"]
    </div>
}
@if (TempData["Info"] != null)
{
    <div class="toast-msg" style="background:#fff7ed;color:#ea580c;border:1.5px solid #fed7aa;" id="toastMsg">
        <i class="bi bi-info-circle-fill" style="font-size:1.3rem;"></i> @TempData["Info"]
    </div>
}

<nav id="sb">
    <button id="sbToggle" onclick="toggle()"><i class="bi bi-chevron-left ti"></i></button>
    <a href="/" class="sb-brand">
        <div class="logo-box"><img src="/images/logo_isuzu.png" alt="Isuzu" asp-append-version="true" /></div>
        <div class="brand-label">
            <div class="bn">Kaizen System</div>
            <div class="bt">Continuous Improvement</div>
        </div>
    </a>
    <ul class="sb-nav">
        <div class="sb-sec" style="margin-top:10px;">Menu</div>
        <li><a asp-controller="Home" asp-action="Index" class="on"><i class="bi bi-grid-1x2-fill"></i><span class="lbl">Dashboard</span></a></li>
        @if (role == "EMPLOYEE" || role == "USER" || role == "ADMIN" || role == "KAIZENCOMMITTEE")
        {
            <li><a asp-controller="Kaizen" asp-action="Create"><i class="bi bi-plus-circle-fill"></i><span class="lbl">Kaizen Generator</span></a></li>
            <li><a asp-controller="Kaizen" asp-action="Index"><i class="bi bi-clock-history"></i><span class="lbl">Proposal History</span></a></li>
        }
        @if (role == "KAIZENCOMMITTEE" || role == "ADMIN")
        {
            <li><a asp-controller="Home" asp-action="AllProposals"><i class="bi bi-list-ul"></i><span class="lbl">All Proposals</span></a></li>
            <li><a asp-controller="Home" asp-action="Winners"><i class="bi bi-trophy-fill"></i><span class="lbl">Best of Month</span></a></li>
            <li><a asp-controller="Home" asp-action="ProposalHistory"><i class="bi bi-clock-history"></i><span class="lbl">Proposals History</span></a></li>
        }
        <li><a asp-controller="Home" asp-action="Profile"><i class="bi bi-person-fill"></i><span class="lbl">My Profile</span></a></li>
    </ul>
    <div class="sb-foot">
        <a asp-controller="Home" asp-action="Logout"><i class="bi bi-box-arrow-left"></i><span class="lbl">Sign Out</span></a>
    </div>
</nav>

<div id="main">
    <div class="topbar">
        <div class="tb-left">
            <div class="sysname">Intelligent Analysis &amp; Reporting System</div>
            <div class="ptitle">Approver Dashboard</div>
            <div style="font-size:.85rem;color:var(--muted);font-weight:600;margin-top:2px;">IARS &rsaquo; Approval</div>
        </div>
        <div class="tb-right">
            @await Html.PartialAsync("_NotificationBell")

            <div class="user-chip">
                <div class="u-avatar">@initial</div>
                <div class="u-info">
                    <div class="uname">@userName</div>
                </div>
            </div>
        </div>
    </div>

    <div class="ca">
        <!-- Stats -->
        <div class="stat-row">
            <div class="stat-card">
                <div class="sc-icon" style="background:#f5f3ff;"><i class="bi bi-clipboard2-check-fill" style="color:#7c3aed;"></i></div>
                <div><div class="sc-val">@ViewBag.PendingApproval</div><div class="sc-lbl">Pending Approval</div></div>
            </div>
            <div class="stat-card">
                <div class="sc-icon" style="background:#eff6ff;"><i class="bi bi-journal-check" style="color:#2563eb;"></i></div>
                <div><div class="sc-val">@ViewBag.TotalAssigned</div><div class="sc-lbl">Total Assigned</div></div>
            </div>
            <div class="stat-card">
                <div class="sc-icon" style="background:#ecfdf5;"><i class="bi bi-patch-check-fill" style="color:#059669;"></i></div>
                <div><div class="sc-val">@ViewBag.ApprovedByMe</div><div class="sc-lbl">Approved</div></div>
            </div>
            <div class="stat-card">
                <div class="sc-icon" style="background:#fff1f2;"><i class="bi bi-x-circle-fill" style="color:#e11d48;"></i></div>
                <div><div class="sc-val">@ViewBag.RejectedByMe</div><div class="sc-lbl">Rejected</div></div>
            </div>
        </div>

        <!-- Pending Approval -->
        <div class="section-title">
            <i class="bi bi-clipboard2-check" style="color:#7c3aed;"></i>
            Proposals Pending Approval
            @if (pending.Any()) { <span style="background:#f5f3ff;color:#7c3aed;border:1.5px solid #ddd6fe;border-radius:20px;padding:3px 12px;font-size:.75rem;">@pending.Count proposals</span> }
        </div>

        @if (pending.Any())
        {
            foreach (var p in pending)
            {
                <div class="proposal-card">
                    <div class="pc-top">
                        <div>
                            <div class="pc-title">@p.Title</div>
                            <div class="pc-meta">
                                <i class="bi bi-person-fill me-1"></i>@(p.Employee?.Name ?? "Unknown")
                                &bull; <i class="bi bi-building me-1"></i>@(p.Employee?.Department ?? "—")
                                &bull; <i class="bi bi-calendar3 me-1"></i>@p.CreatedAt.ToString("dd MMM yyyy")
                            </div>
                            @if (p.Reviewer != null)
                            {
                                <div class="hod-chip"><i class="bi bi-person-check-fill"></i> Reviewed by @p.Reviewer.Name &mdash; @(p.ReviewedAt?.ToString("dd MMM") ?? "—")</div>
                            }
                        </div>
                        <span class="badge-status bs-hodok"><i class="bi bi-check2-circle"></i> Reviewer Approved</span>
                    </div>
                    @if (!string.IsNullOrEmpty(p.ReviewerComment))
                    {
                        <div style="font-size:.84rem;padding:8px 12px;background:#eff6ff;border-radius:8px;color:#1d4ed8;margin-bottom:8px;">
                            <i class="bi bi-chat-left-quote me-1"></i> <strong>Reviewer Remarks:</strong> @p.ReviewerComment
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(p.Objective))
                    {
                        <div style="font-size:.87rem;color:var(--muted);padding:8px 12px;background:#f8f9fc;border-radius:8px;line-height:1.6;">
                            <strong>Objective:</strong> @p.Objective
                        </div>
                    }
                    <div class="action-row" id="btns-@p.Id">
                        <a asp-controller="Kaizen" asp-action="Details" asp-route-id="@p.Id" class="btn-view-sm" target="_blank">
                            <i class="bi bi-eye"></i> View Proposal
                        </a>
                        <button class="btn-approve" onclick="showForm(@p.Id,'approve')"><i class="bi bi-patch-check-fill"></i> Approve</button>
                        <button class="btn-reject" onclick="showForm(@p.Id,'reject')"><i class="bi bi-x-circle-fill"></i> Reject</button>
                    </div>
                    <form asp-controller="Kaizen" asp-action="FinalApprove" method="post" id="fapprove-@p.Id" style="display:none;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@p.Id" />
                        <textarea class="remarks-area" name="remarks" rows="3" placeholder="Approval remarks (optional)..."></textarea>
                        <div class="action-row">
                            <button type="submit" class="btn-approve"><i class="bi bi-patch-check-fill"></i> Confirm Approval</button>
                            <button type="button" class="btn-view-sm" onclick="hideForm(@p.Id)">Cancel</button>
                        </div>
                    </form>
                    <form asp-controller="Kaizen" asp-action="FinalReject" method="post" id="freject-@p.Id" style="display:none;">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@p.Id" />
                        <textarea class="remarks-area" name="remarks" rows="3" placeholder="Reason for final rejection..." required></textarea>
                        <div class="action-row">
                            <button type="submit" class="btn-reject"><i class="bi bi-x-circle-fill"></i> Confirm Rejection</button>
                            <button type="button" class="btn-view-sm" onclick="hideForm(@p.Id)">Cancel</button>
                        </div>
                    </form>
                </div>
            }
        }
        else
        {
            <div class="empty-card">
                <i class="bi bi-clipboard2-check" style="font-size:3rem;opacity:.15;display:block;margin-bottom:16px;color:var(--muted);"></i>
                <div style="font-weight:800;font-size:1.1rem;color:var(--tx);">No Proposals Pending Approval</div>
                <div style="color:var(--muted);font-size:.9rem;margin-top:8px;">Proposals approved by Reviewer will appear here.</div>
            </div>
        }

        <!-- History -->
        @if (myHistory.Any())
        {
            <div class="section-title mt-4">
                <i class="bi bi-clock-history" style="color:var(--muted);"></i> My Decision History
            </div>
            @foreach (var p in myHistory)
            {
                <div class="proposal-card" style="opacity:.9;">
                    <div class="pc-top">
                        <div>
                            <div class="pc-title">@p.Title</div>
                            <div class="pc-meta">
                                <i class="bi bi-person-fill me-1"></i>@(p.Employee?.Name ?? "Unknown")
                                &bull; <i class="bi bi-building me-1"></i>@(p.Employee?.Department ?? "—")
                                &bull; <i class="bi bi-calendar3 me-1"></i>Created: @p.CreatedAt.ToString("dd MMM yyyy")
                                &bull; <i class="bi bi-calendar-check-fill me-1"></i>Decided: @(p.ApprovedAt?.ToString("dd MMM yyyy") ?? "—")
                            </div>
                            @if (p.Reviewer != null)
                            {
                                <div class="hod-chip"><i class="bi bi-person-check-fill"></i> Reviewed by @p.Reviewer.Name &mdash; @(p.ReviewedAt?.ToString("dd MMM") ?? "—")</div>
                            }
                        </div>
                        @{
                            var cls = p.Status switch {
                                "FinalApproved" or "Released" => "bs-approved",
                                "FinalRejected" => "bs-rejected",
                                _ => "bs-approved"
                            };
                            var lbl = p.Status switch {
                                "FinalApproved" => "Approved",
                                "Released" => "Released",
                                "FinalRejected" => "Rejected",
                                _ => p.Status
                            };
                        }
                        <span class="badge-status @cls">@lbl</span>
                    </div>
                    @if (!string.IsNullOrEmpty(p.ReviewerComment))
                    {
                        <div style="font-size:.84rem;padding:8px 12px;background:#eff6ff;border-radius:8px;color:#1d4ed8;margin-bottom:8px;margin-top:8px;">
                            <i class="bi bi-chat-left-quote me-1"></i> <strong>Reviewer Remarks:</strong> @p.ReviewerComment
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(p.ApprovalComment))
                    {
                        <div style="font-size:.84rem;padding:8px 12px;background:#f0fdf4;border-radius:8px;color:#16a34a;margin-bottom:8px;border:1px solid #dcfce7;margin-top:8px;">
                            <i class="bi bi-chat-left-text me-1"></i> <strong>My Remarks:</strong> @p.ApprovalComment
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(p.Objective))
                    {
                        <div style="font-size:.87rem;color:var(--muted);padding:8px 12px;background:#f8f9fc;border-radius:8px;line-height:1.6;margin-top:8px;">
                            <strong>Objective:</strong> @p.Objective
                        </div>
                    }
                    <div class="action-row" style="margin-top:14px; padding-top:14px;">
                        <a asp-controller="Kaizen" asp-action="Details" asp-route-id="@p.Id" class="btn-view-sm" target="_blank">
                            <i class="bi bi-eye"></i> View Proposal
                        </a>
                    </div>
                </div>
            }
        }
    </div>
</div>

<script>
    function toggle() {
        const sb = document.getElementById('sb');
        sb.classList.toggle('collapsed');
        localStorage.setItem('sbCol', sb.classList.contains('collapsed'));
    }
    window.addEventListener('DOMContentLoaded', () => {
        if (localStorage.getItem('sbCol') === 'true') document.getElementById('sb').classList.add('collapsed');
        const t = document.getElementById('toastMsg');
        if (t) setTimeout(() => t.style.opacity = '0', 3500);
    });
    function showForm(id, type) {
        document.getElementById('btns-' + id).style.display = 'none';
        document.getElementById(type === 'approve' ? 'fapprove-' + id : 'freject-' + id).style.display = 'block';
    }
    function hideForm(id) {
        document.getElementById('btns-' + id).style.display = 'flex';
        document.getElementById('fapprove-' + id).style.display = 'none';
        document.getElementById('freject-' + id).style.display = 'none';
    }
</script>
</body>
</html>
