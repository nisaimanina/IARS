@model IARS.Models.DashboardViewModel

@{
    Layout = null;
    ViewData["Title"] = "Dashboard";
    var userName = Context.Session.GetString("UserName") ?? "User";
    var role = (Context.Session.GetString("UserRole") ?? "User").ToUpper();
    var roleLabel = role switch {
        "KAIZENCOMMITTEE" => "Kaizen Committee",
        "HOD"             => "Reviewer",
        "FINALAPPROVER"   => "Approver",
        "REVIEWER"        => "Reviewer",
        "ADMIN"           => "Administrator",
        _                 => "Employee"
    };
    var firstName = userName.Split(' ')[0];
    var initial = userName.Length > 0 ? userName[0].ToString().ToUpper() : "U";
    var hour = DateTime.Now.Hour;
    var greeting = hour < 12 ? "Good Morning" : hour < 17 ? "Good Afternoon" : "Good Evening";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard — IARS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --red:#ED1C24; --red-soft:#fff0f0;
            --dark:#0e1118;
            --sidebar-w:300px; --sidebar-col:80px;
            --topbar-h:100px; --tr:0.3s ease;
            --tx:#1a1d2e; --muted:#7c8db5;
            --bg:#f4f6fa; --border:#e4e9f4;
        }
        body { font-family:'Inter',system-ui,sans-serif; background:var(--bg); overflow:hidden; height:100vh; display:flex; font-size:15.5px; }

        /* ════ SIDEBAR ════ */
        #sb { width:var(--sidebar-w); min-height:100vh; background:var(--dark); display:flex; flex-direction:column; flex-shrink:0; transition:all var(--tr); position:relative; z-index:100; }
        #sb.collapsed { width:var(--sidebar-col); padding-top:20px; }
        #sbToggle { position:absolute; top:35px; right:-16px; width:32px; height:32px; background:var(--red); border:none; border-radius:50%; color:white; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:0.9rem; z-index:200; box-shadow:0 4px 14px rgba(237,28,36,0.4); transition:transform .2s; }
        #sbToggle:hover { transform:scale(1.1); }
        #sb.collapsed #sbToggle .ti { transform:rotate(180deg); }

        /* Brand */
        .sb-brand { display:flex; flex-direction:column; align-items:center; padding:32px 18px 24px; border-bottom:1px solid rgba(255,255,255,0.05); text-decoration:none; overflow:hidden; }
        .logo-box { background:white; border-radius:14px; padding:12px 16px; display:flex; align-items:center; justify-content:center; width:100%; max-width:180px; box-shadow:0 6px 16px rgba(0,0,0,0.25); }
        .logo-box img { width:100%; max-width:150px; height:auto; object-fit:contain; display:block; }
        .brand-label { margin-top:14px; text-align:center; overflow:hidden; }
        .brand-label .bn { color:white; font-weight:900; font-size:1.15rem; letter-spacing:-0.2px; white-space:nowrap; }
        .brand-label .bt { color:rgba(255,255,255,0.32); font-size:0.75rem; letter-spacing:1px; text-transform:uppercase; margin-top:4px; white-space:nowrap; }
        #sb.collapsed .sb-brand { display:none; }

        /* Nav */
        .sb-sec { padding:24px 22px 8px; font-size:0.72rem; font-weight:800; letter-spacing:2px; text-transform:uppercase; color:rgba(255,255,255,0.2); white-space:nowrap; }
        #sb.collapsed .sb-sec { opacity:0; height:28px; padding:0; }
        .sb-nav { list-style:none; padding:4px 12px; flex-grow:1; }
        .sb-nav a { display:flex; align-items:center; gap:16px; padding:12px 16px; color:rgba(255,255,255,0.48); text-decoration:none; border-radius:12px; margin-bottom:6px; transition:all var(--tr); white-space:nowrap; overflow:hidden; font-size:1.05rem; font-weight:600; letter-spacing:-0.1px; }
        .sb-nav a:hover { background:rgba(255,255,255,0.07); color:rgba(255,255,255,0.88); }
        .sb-nav a.on { background:var(--red); color:white; }
        .sb-nav a i { font-size:1.3rem; flex-shrink:0; width:24px; text-align:center; }
        .sb-nav .lbl { overflow:hidden; white-space:nowrap; }
        #sb.collapsed .sb-nav .lbl { display:none; }

        /* Footer */
        .sb-foot { padding:14px 12px; border-top:1px solid rgba(255,255,255,0.05); }
        .sb-foot a { display:flex; align-items:center; gap:16px; padding:12px 16px; border-radius:12px; color:rgba(255,255,255,0.38); text-decoration:none; font-size:1.05rem; font-weight:600; transition:all var(--tr); white-space:nowrap; overflow:hidden; }
        .sb-foot a:hover { background:rgba(237,28,36,0.14); color:var(--red); }
        .sb-foot a i { font-size:1.3rem; flex-shrink:0; width:24px; text-align:center; }
        #sb.collapsed .sb-foot .lbl { display:none; }

        /* MAIN */
        #main { flex-grow:1; display:flex; flex-direction:column; overflow:hidden; }
        .topbar { height:var(--topbar-h); background:white; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; padding:0 36px; flex-shrink:0; }
        .tb-left { display:flex; flex-direction:column; justify-content:center; }
        .tb-left .sysname { font-size:0.75rem; color:var(--red); font-weight:800; letter-spacing:0.8px; margin:0 0 4px 0; text-transform:uppercase; }
        .tb-left .ptitle { font-size:1.55rem; font-weight:900; color:var(--tx); letter-spacing:-0.4px; margin:0; }
        .tb-right { display:flex; align-items:center; justify-content:flex-end; gap:16px; }
        .user-chip { display:flex; align-items:center; gap:14px; background:#f7f8fc; border:1.5px solid var(--border); border-radius:14px; padding:6px 18px 6px 8px; cursor:pointer; transition:border .2s; }
        .user-chip:hover { border-color:#c8d0e8; }
        .u-avatar { width:46px; height:46px; background:#2563eb; color:white; border-radius:12px; display:flex; align-items:center; justify-content:center; font-weight:900; font-size:1.15rem; letter-spacing:-0.5px; flex-shrink:0; }
        .u-info { text-align:left; }
        .u-info .uname { font-weight:800; font-size:1rem; color:var(--tx); line-height:1.2; }
        .u-info .urole { font-size:0.8rem; color:var(--muted); font-weight:600; }

        /* Content */
        .ca { flex-grow:1; overflow-y:auto; padding:32px 36px; }

        /* Greeting */
        .greet { margin-bottom:28px; }
        .greet h2 { font-size:1.75rem; font-weight:900; color:var(--tx); letter-spacing:-0.5px; }
        .greet p { font-size:1rem; color:var(--muted); margin-top:6px; }

        /* Stat Cards */
        .stat { background:white; border-radius:16px; padding:24px 26px; border:1px solid var(--border); display:flex; align-items:center; gap:20px; transition:transform .2s,box-shadow .2s; }
        .stat:hover { transform:translateY(-4px); box-shadow:0 8px 30px rgba(0,0,0,0.06); }
        .s-icon { width:60px; height:60px; border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:1.7rem; flex-shrink:0; }
        .s-lbl { font-size:0.8rem; font-weight:800; color:var(--muted); text-transform:uppercase; letter-spacing:0.8px; }
        .s-val { font-size:2.3rem; font-weight:900; color:var(--tx); line-height:1.1; margin-top:2px; letter-spacing:-1px; }
        .s-trend { font-size:0.8rem; font-weight:700; margin-top:4px; }

        /* Hero */
        .hero { background:linear-gradient(135deg,#0e1118 0%,#1e2540 100%); border-radius:20px; padding:36px; color:white; position:relative; overflow:hidden; }
        .hero::before { content:''; position:absolute; top:-50px; right:-50px; width:240px; height:240px; background:rgba(237,28,36,0.15); border-radius:50%; }
        .hero::after { content:''; position:absolute; bottom:-70px; right:60px; width:180px; height:180px; background:rgba(237,28,36,0.08); border-radius:50%; }
        .hero h2 { font-size:1.6rem; font-weight:900; margin-bottom:12px; position:relative; letter-spacing:-0.3px; }
        .hero p { color:rgba(255,255,255,0.6); font-size:0.95rem; line-height:1.7; max-width:400px; position:relative; }
        .hero-btn { display:inline-flex; align-items:center; gap:10px; background:var(--red); color:white; padding:14px 28px; border-radius:12px; font-weight:800; font-size:0.95rem; text-decoration:none; margin-top:22px; position:relative; transition:opacity .2s; }
        .hero-btn:hover { opacity:.9; color:white; }

        /* Quick Actions */
        .qa-card { background:white; border-radius:18px; border:1px solid var(--border); padding:26px; }
        .qa-card h5 { font-size:0.88rem; font-weight:800; color:var(--muted); text-transform:uppercase; letter-spacing:1px; margin-bottom:20px; }
        .qa-btn { display:flex; align-items:center; gap:16px; padding:16px 18px; border-radius:14px; background:var(--bg); border:1.5px solid transparent; text-decoration:none; transition:all .2s; margin-bottom:12px; }
        .qa-btn:hover { border-color:var(--red); background:var(--red-soft); }
        .qa-icon { width:44px; height:44px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.3rem; flex-shrink:0; }
        .qa-title { font-size:1rem; font-weight:800; color:var(--tx); margin:0; }
        .qa-sub { font-size:0.82rem; color:var(--muted); margin:0 0 2px 0; }

        /* Tip */
        .tip { background:linear-gradient(135deg,#fffbeb,#fef3c7); border:1.5px solid #fde68a; border-radius:16px; padding:22px 26px; }
        .tip-hd { display:flex; align-items:center; gap:10px; margin-bottom:10px; }
        .tip-hd span { font-size:1.6rem; }
        .tip-hd b { font-size:0.88rem; font-weight:800; color:#92400e; text-transform:uppercase; letter-spacing:0.5px; }
        .tip p { font-size:0.95rem; color:#78350f; line-height:1.65; margin:0; font-weight:500; }

        /* Activity */
        .act-card { background:white; border-radius:18px; border:1px solid var(--border); overflow:hidden; height:100%; }
        .act-hd { padding:22px 26px; border-bottom:1px solid var(--border); display:flex; justify-content:space-between; align-items:center; }
        .act-hd h5 { font-weight:900; font-size:1.1rem; color:var(--tx); margin:0; }
        .act-item { display:flex; align-items:flex-start; gap:16px; padding:16px 26px; transition:background .15s; border-bottom:1px solid #f8f9fc; }
        .act-item:hover { background:#fafbfc; }
        .a-dot { width:10px; height:10px; border-radius:50%; background:#dde2ef; flex-shrink:0; margin-top:6px; }
        .a-dot.r { background:var(--red); }
        .a-action { font-size:0.92rem; font-weight:700; color:var(--tx); }
        .a-time { font-size:0.8rem; color:var(--muted); margin-top:3px; }

        ::-webkit-scrollbar { width:6px; }
        ::-webkit-scrollbar-thumb { background:#cfd6e4; border-radius:10px; }
    </style>
</head>
<body>

<!-- ▌SIDEBAR ▐ -->
<nav id="sb">
    <button id="sbToggle" onclick="toggle()"><i class="bi bi-chevron-left ti"></i></button>

    <a href="/" class="sb-brand">
        <div class="logo-box"><img src="/images/logo_isuzu.png" alt="Isuzu Logo" asp-append-version="true" /></div>
        <div class="brand-label">
            <div class="bn">Kaizen System</div>
            <div class="bt">Continuous Improvement</div>
        </div>
    </a>

    <ul class="sb-nav">
        <div class="sb-sec" style="margin-top:10px;">Menu</div>
        <li><a asp-controller="Home" asp-action="Index" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "on" : "")"><i class="bi bi-grid-1x2-fill"></i><span class="lbl">Dashboard</span></a></li>
        
        @if (role == "KAIZENCOMMITTEE" || role == "ADMIN")
        {
            <li><a asp-controller="Home" asp-action="AllProposals" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "AllProposals" ? "on" : "")"><i class="bi bi-list-ul"></i><span class="lbl">All Proposals</span></a></li>
            <li><a asp-controller="Home" asp-action="Winners" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Winners" ? "on" : "")"><i class="bi bi-trophy-fill"></i><span class="lbl">Best of Month</span></a></li>
            <li><a asp-controller="Home" asp-action="ProposalHistory" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "ProposalHistory" ? "on" : "")"><i class="bi bi-clock-history"></i><span class="lbl">Proposals History</span></a></li>
        }
        
        @if (role == "EMPLOYEE" || role == "USER" || role == "KAIZENCOMMITTEE" || role == "ADMIN")
        {
            <li><a asp-controller="Kaizen" asp-action="Create" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Create" ? "on" : "")"><i class="bi bi-plus-circle-fill"></i><span class="lbl">Kaizen Generator</span></a></li>
            <li><a asp-controller="Kaizen" asp-action="Index" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Kaizen" ? "on" : "")"><i class="bi bi-clock-history"></i><span class="lbl">My Proposals</span></a></li>
        }
        
        <li><a asp-controller="Home" asp-action="Profile" class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "on" : "")"><i class="bi bi-person-fill"></i><span class="lbl">My Profile</span></a></li>
    </ul>

    <div class="sb-foot">
        <a asp-controller="Home" asp-action="Logout"><i class="bi bi-box-arrow-left"></i><span class="lbl">Log Out</span></a>
    </div>
</nav>

<!-- ▌MAIN CONTENT ▐ -->
<div id="main">
    <div class="topbar">
        <div class="tb-left">
            <div class="sysname">Intelligent Analysis &amp; Reporting System</div>
            <div class="ptitle">Dashboard</div>
            <div style="font-size:0.85rem;color:var(--muted);font-weight:600;margin-top:2px;">IARS &rsaquo; Overview</div>
        </div>
        <div class="tb-right">
            @await Html.PartialAsync("_NotificationBell")

            <div class="user-chip">
                <div class="u-avatar">@initial</div>
                <div class="u-info">
                    <div class="uname">@userName</div>
                </div>
            </div>
        </div>
    </div>

    <div class="ca">
        <!-- Greeting -->
        <div class="greet">
            <h2>@greeting, @firstName! 👋</h2>
            <p>Here's your Kaizen overview for today.</p>
        </div>

        <!-- Stats -->
        <div class="row g-4 mb-4">
            <div class="col-md-3">
                <div class="stat">
                    <div class="s-icon" style="background:#EFF6FF;"><i class="bi bi-journal-text" style="color:#2563EB;"></i></div>
                    <div>
                        <div class="s-lbl">Total</div>
                        <div class="s-val">@ViewBag.TotalProposals</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat">
                    <div class="s-icon" style="background:#F0FDF4;"><i class="bi bi-check-circle-fill" style="color:#16A34A;"></i></div>
                    <div>
                        <div class="s-lbl">Approved</div>
                        <div class="s-val">@ViewBag.ApprovedProposals</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat">
                    <div class="s-icon" style="background:#FFF7ED;"><i class="bi bi-clock-fill" style="color:#EA580C;"></i></div>
                    <div>
                        <div class="s-lbl">Pending Review</div>
                        <div class="s-val">@ViewBag.PendingProposals</div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="stat">
                    <div class="s-icon" style="background:#FFF1F2;"><i class="bi bi-x-circle-fill" style="color:#E11D48;"></i></div>
                    <div>
                        <div class="s-lbl">Rejected</div>
                        <div class="s-val">@ViewBag.RejectedProposals</div>
                    </div>
                </div>
            </div>
        </div>

        @if (ViewBag.RejectedProposals > 0)
        {
            <div style="background:#fff1f2; border:1.5px solid #fecdd3; border-radius:16px; padding:20px 24px; margin-bottom:28px; display:flex; align-items:center; gap:20px; animation: pulse 2s infinite;">
                <div style="width:50px; height:50px; background:#e11d48; border-radius:50%; display:flex; align-items:center; justify-content:center; color:white; font-size:1.4rem; flex-shrink:0;">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                </div>
                <div style="flex-grow:1;">
                    <div style="font-weight:900; color:#9f1239; font-size:1.05rem;">Attention Required</div>
                    <div style="color:#e11d48; font-size:0.92rem; font-weight:600;">You have @ViewBag.RejectedProposals rejected proposal(s). Please check the remarks and resubmit.</div>
                </div>
                <a asp-controller="Kaizen" asp-action="Index" style="background:white; color:#e11d48; border:1.5px solid #fecdd3; padding:8px 18px; border-radius:10px; font-weight:800; text-decoration:none; font-size:0.88rem;">View History</a>
            </div>
        }
        
        <style>
            @@keyframes pulse {
                0% { box-shadow: 0 0 0 0 rgba(225, 29, 72, 0.2); }
                70% { box-shadow: 0 0 0 10px rgba(225, 29, 72, 0); }
                100% { box-shadow: 0 0 0 0 rgba(225, 29, 72, 0); }
            }
        </style>

        @if (ViewBag.ApprovedProposals > 0)
        {
            @* Optional: Show a small success banner if there was a recent approval in the last 24h *@
            var recentApproval = ((List<IARS.Models.History>)ViewBag.RecentActivity)
                .FirstOrDefault(h => h.Action.Contains("Approved") && h.Timestamp > DateTime.Now.AddDays(-1));
            
            if (recentApproval != null)
            {
                <div style="background:#f0fdf4; border:1.5px solid #bbf7d0; border-radius:16px; padding:18px 24px; margin-bottom:28px; display:flex; align-items:center; gap:20px;">
                    <div style="width:50px; height:50px; background:#16a34a; border-radius:50%; display:flex; align-items:center; justify-content:center; color:white; font-size:1.4rem; flex-shrink:0;">
                        <i class="bi bi-check-lg"></i>
                    </div>
                    <div style="flex-grow:1;">
                        <div style="font-weight:900; color:#166534; font-size:1.05rem;">New Approval Received!</div>
                        <div style="color:#16a34a; font-size:0.92rem; font-weight:600;">@recentApproval.Description</div>
                    </div>
                    <a asp-controller="Kaizen" asp-action="Index" style="background:white; color:#16a34a; border:1.5px solid #bbf7d0; padding:8px 18px; border-radius:10px; font-weight:800; text-decoration:none; font-size:0.88rem;">Track Progress</a>
                </div>
            }
        }

        <div class="row g-4">
            <!-- Left: Hero + Tip -->
            <div class="col-lg-5 d-flex flex-column gap-4">
                <div class="hero flex-grow-1">
                    <h2>Launch Your Next Kaizen ✨</h2>
                    <p>Let the AI engine draft a data-driven improvement proposal for you in seconds. Fast, structured, and professional.</p>
                    <a asp-controller="Kaizen" asp-action="Create" class="hero-btn">
                        <i class="bi bi-stars"></i> Start Generating
                    </a>
                </div>
                <div class="tip">
                    <div class="tip-hd"><span>💡</span><b>Kaizen Tip</b></div>
                    <p>"Small daily improvements compound into extraordinary results. Every Kaizen, no matter how small, drives continuous progress." 🚀</p>
                </div>
            </div>

            <!-- Middle: Quick Actions -->
            <div class="col-lg-4">
                <div class="qa-card">
                    <h5>⚡ Quick Actions</h5>
                    <a asp-controller="Kaizen" asp-action="Create" class="qa-btn">
                        <div class="qa-icon" style="background:#fff0f0;"><i class="bi bi-plus-circle-fill" style="color:var(--red);"></i></div>
                        <div><p class="qa-title">New Proposal</p><p class="qa-sub">AI-powered generator</p></div>
                    </a>
                    <a asp-controller="Kaizen" asp-action="Index" class="qa-btn">
                        <div class="qa-icon" style="background:#eff6ff;"><i class="bi bi-clock-history" style="color:#2563eb;"></i></div>
                        <div><p class="qa-title">View History</p><p class="qa-sub">All saved proposals</p></div>
                    </a>
                    <a asp-controller="Home" asp-action="Profile" class="qa-btn">
                        <div class="qa-icon" style="background:#f5f3ff;"><i class="bi bi-person-fill" style="color:#7c3aed;"></i></div>
                        <div><p class="qa-title">My Profile</p><p class="qa-sub">Account information</p></div>
                    </a>
                </div>
            </div>

            <!-- Right: Activity -->
            <div class="col-lg-3">
                <div class="act-card">
                    <div class="act-hd">
                        <h5>Recent Activity</h5>
                        <a asp-controller="Kaizen" asp-action="Index" style="font-size:0.85rem;color:var(--red);text-decoration:none;font-weight:800;">All</a>
                    </div>
                    @if (ViewBag.RecentActivity != null && ((List<IARS.Models.History>)ViewBag.RecentActivity).Any())
                    {
                        @foreach (var activity in (List<IARS.Models.History>)ViewBag.RecentActivity)
                        {
                            var dotClass = activity.Action.Contains("Approved") ? "success-dot" : 
                                          activity.Action.Contains("Rejected") ? "danger-dot" : 
                                          activity.Action.Contains("Submit")   ? "info-dot" : "r";
                            <div class="act-item">
                                <div class="a-dot @dotClass"></div>
                                <div>
                                    <div class="a-action">@activity.Action</div>
                                    <div class="a-time">@activity.Timestamp.ToString("dd MMM, HH:mm")</div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div style="text-align:center;padding:50px 20px;color:var(--muted);font-size:0.9rem;">
                            <i class="bi bi-inbox d-block mb-3" style="font-size:2.5rem;opacity:.2;"></i>No activity yet.
                        </div>
                    }
                </div>
            </div>
        </div>

        <style>
            .success-dot { background:#16a34a !important; box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.2); }
            .danger-dot { background:#e11d48 !important; box-shadow: 0 0 0 3px rgba(225, 29, 72, 0.2); }
            .info-dot { background:#2563eb !important; box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.2); }
        </style>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/twemoji/14.0.2/twemoji.min.js" crossorigin="anonymous"></script>
<script>
    function toggle() {
        const sb = document.getElementById('sb');
        sb.classList.toggle('collapsed');
        localStorage.setItem('sbCol', sb.classList.contains('collapsed'));
    }
    window.addEventListener('DOMContentLoaded', () => {
        if (localStorage.getItem('sbCol') === 'true') document.getElementById('sb').classList.add('collapsed');
        twemoji.parse(document.body, { folder: 'svg', ext: '.svg' });
    });
</script>
</body>
</html>