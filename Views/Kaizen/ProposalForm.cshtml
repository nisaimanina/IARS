@using System.Text.RegularExpressions
@using Microsoft.AspNetCore.Http
@model IARS.Models.KaizenProposal

@{
    Layout = null;
    ViewData["Title"] = "KAIZEN REPORT - " + Model.Id;





    string GetImpactValue(string? text, string label) {
    if (string.IsNullOrEmpty(text)) return "";
    // Pattern matches label followed by ':' handling CRLF or LF line endings
    var pattern = $@"(?:^|\r?\n){label}\s*:\s*(.*?)(?=\r?\n|$)";
    var match = Regex.Match(text, pattern, RegexOptions.IgnoreCase);
    if (match.Success) return match.Groups[1].Value.Trim();
    // Fallback: label without colon
    var altPattern = $@"(?:^|\r?\n){label}\s+(.*?)(?=\r?\n|$)";
    var altMatch = Regex.Match(text, altPattern, RegexOptions.IgnoreCase);
    if (altMatch.Success) return altMatch.Groups[1].Value.Trim();
    // Return full trimmed text if specific label not found
    return text.Trim();
}

    string GetDeptAbbr(string? dept) {
        if (string.IsNullOrEmpty(dept)) return "IHMSB";
        string d = dept.Trim();
        string du = d.ToUpper();

        // Multi-word abbreviation: take first letter of each significant word
        var words = System.Text.RegularExpressions.Regex.Split(d.Trim(), @"\s+")
            .Where(w => w.Length > 1 && !new[]{"AND","OF","THE","FOR","IN","&"}.Contains(w.ToUpper()))
            .ToArray();
        if (words.Length >= 2) {
            string abbr = string.Concat(words.Select(w => char.ToUpper(w[0])));
            return abbr.Length > 5 ? abbr.Substring(0, 5) : abbr;
        }

        // Single word fallbacks
        if (du.Contains("FINANCE")) return "FIN";
        if (du.Contains("MAINTENANCE")) return "MNT";
        if (du.Contains("QUALITY")) return "QA";
        if (du.Contains("HUMAN")) return "HR";
        if (du.Contains("SAFETY")) return "SHE";
        if (du.Contains("PROCUREMENT") || du.Contains("PURCHASE")) return "PCH";
        if (du.Contains("LOGISTIC")) return "LOG";
        if (du.Contains("INFORMATION")) return "IT";
        if (d.Length > 4) return du.Substring(0, 3);
        return du;
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&family=Roboto+Mono:wght@500&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --isuzu-red: #cc0000;
            --dark-text: #1a1a1a;
            --light-gray: #f4f4f4;
            --border-color: #000000;
        }

        body { 
            background-color: #525659; /* Tema PDF Reader */
            font-family: 'Inter', sans-serif; 
            margin: 0; 
            padding: 80px 0 40px; /* Ruang untuk top bar */
            overflow-y: auto;
        }

        .paper { 
            background: white; 
            width: 210mm; 
            min-height: 297mm; 
            margin: 0 auto 30px; 
            padding: 8mm; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            position: relative;
        }

        .top-nav {
            position: fixed; top: 0; left: 0; right: 0;
            height: 65px; background: #1a1d2e;
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 40px; z-index: 3000;
            box-shadow: 0 4px 15px rgba(0,0,0,0.4);
            border-bottom: 2px solid var(--isuzu-red);
        }

        .nav-logo { color: white; font-weight: 900; letter-spacing: 1px; font-size: 1.2rem; }
        .nav-actions { display: flex; gap: 10px; }

        .btn-action {
            padding: 8px 18px; border-radius: 6px; font-size: 13px; font-weight: 700;
            text-decoration: none; border: none; cursor: pointer; transition: all 0.2s;
            display: flex; align-items: center; gap: 8px; text-transform: uppercase;
        }

        .btn-back { background: rgba(255,255,255,0.1); color: white; }
        .btn-back:hover { background: rgba(255,255,255,0.2); }
        
        .btn-print { background: var(--isuzu-red); color: white; }
        .btn-print:hover { background: #ff0000; transform: translateY(-1px); }

        .btn-dl { background: white; color: #1a1d2e; }
        .btn-dl:hover { background: #f0f0f0; }

        .divider { width: 1px; height: 30px; background: rgba(255,255,255,0.2); margin: 0 5px; }

        /* Detail styling */
        .doc-header {
            display: flex;
            align-items: flex-start;
            justify-content: flex-start;
            gap: 0;
            width: 100%;
            box-sizing: border-box;
            margin-bottom: 8px;
        }
        .header-logo { width: 85px; flex-shrink: 0; padding-top: 14px; padding-left: 10px; }
        .header-logo img { width: 100%; height: auto; }
        .header-title-box { flex: 1; min-width: 200px; max-width: 350px; text-align: left; display: flex; align-items: flex-start; padding-top: 0; padding-left: 0; }
        .header-title-box h1 { 
            color: #0000aa; 
            font-size: 26px; 
            font-weight: 900; 
            margin: 0; 
            font-family: 'Arial', sans-serif;
            letter-spacing: -0.5px;
            text-transform: uppercase;
            -webkit-text-stroke: 0.5px #000;
            display: block;
            transform: scaleY(3.5);
            transform-origin: top left;
            line-height: 1;
            white-space: nowrap;
        }
        
        .sig-table-wrapper { position: relative; margin-left: 42px; flex-shrink: 0; }
        .date-label-side { 
            position: absolute; left: -42px; bottom: 0; width: 42px; height: 17px; 
            border: 1.5px solid #000; border-right: none; background: #fff; 
            font-weight: 700; font-size: 8px; display: flex; align-items: center; justify-content: center;
        }
        .sig-table-new { border-collapse: collapse; border: 1.5px solid #000; width: 285px; font-size: 9px; }
        .sig-table-new th, .sig-table-new td { border: 1px solid #000; text-align: center; padding: 0 3px; overflow: hidden; }
        .sig-table-new th { font-weight: 700; font-size: 9.5px; height: 18px; }
        .sig-table-new .label-col { background: #fff; text-align: left; padding-left: 5px; font-weight: 700; width: 40px; font-size: 8.5px; white-space: nowrap; height: 16px; }
        .sig-table-new .content-col { width: 85px; text-align: left; font-size: 8px; line-height: 1; max-width: 85px; word-wrap: break-word; padding-left: 5px; }
        .sig-table-new .date-row td { height: 15px; text-align: center; font-weight: 700; font-size: 8px; padding: 0 2px; }

        .report-impact-grid { display: flex; justify-content: space-between; align-items: center; margin: 8px 0; }
        .report-impact-item { display: flex; align-items: center; gap: 8px; font-size: 11px; font-weight: 600; flex: 1; }
        .box-check { width: 35px; height: 35px; border: 1.5px solid #000; flex-shrink: 0; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: normal; background: #fff; }
        .isuzu-id-badge { font-size: 9px; font-weight: 900; color: #fff; padding: 2px 6px; border-radius: 12px; margin-top: 2px; display: inline-block; }
        .info-table { width: 100%; border: 1px solid var(--border-color); margin-bottom: 12px; font-size: 11px; }
        .info-table td { border: 1px solid var(--border-color); padding: 5px; }
        .label-cell { background-color: var(--light-gray); font-weight: 700; width: 15%; text-transform: uppercase; font-size: 9px; }
        .sig-box { width: 220px; float: right; border-collapse: collapse; margin-bottom: 10px; }
        .sig-box th, .sig-box td { border: 1px solid var(--border-color); text-align: center; font-size: 9px; width: 73px; }
        .sig-box th { background: var(--light-gray); padding: 3px; }
        .sig-box td { height: 50px; vertical-align: middle; }
        .section-title { background: #333; color: white; padding: 3px 10px; font-size: 11px; font-weight: 700; margin-top: 10px; text-transform: uppercase; }
        .content-block { border: 1px solid var(--border-color); border-top: none; padding: 10px; font-size: 11px; }
        .comparison-container { display: flex; align-items: stretch; gap: 0; }
        .compare-box { flex: 1; padding: 5px; border: 1.5px solid #000; position: relative; }
        .arrow-space { width: 35px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; position: relative; z-index: 10; }
        .img-container { height: 170px; border: 1px solid #eee; margin-bottom: 5px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: #fafafa; }
        .img-container img { max-width: 100%; max-height: 100%; object-fit: contain; }
        
        .rank-stamp {
            border: 3px double var(--isuzu-red); color: var(--isuzu-red); width: 70px; height: 70px; border-radius: 50%;
            display: flex; flex-direction: column; align-items: center; justify-content: center; font-weight: 800; margin: 0 auto; transform: rotate(-10deg);
        }
        .mini-stamp {
            border: 3px double #000080;
            color: #000080;
            width: 62px; height: 62px;
            border-radius: 50%;
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 6px;
            line-height: 1.1;
            text-align: center;
            text-transform: uppercase;
            font-weight: 700;
            transform: rotate(-5deg);
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 1px 1px 3px rgba(0,0,0,0.1);
        }
        .mini-stamp .stamp-name { font-size: 6px; font-weight: 800; max-width: 50px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
        .mini-stamp .stamp-center { border-top: 1px solid currentColor; border-bottom: 1px solid currentColor; padding: 1px 0; margin: 1px 0; font-size: 7px; width: 85%; font-weight: 900; }
        .mini-stamp .stamp-date { font-size: 5.5px; opacity: 0.8; }
        .mini-stamp.red { border-color: #cc0000; color: #cc0000; }
        .mini-stamp.green { border-color: #28a745; color: #28a745; }

        .score-font { font-family: 'Roboto Mono', monospace; font-size: 16px; font-weight: 700; }

        .form-underline {
            line-height: 20px;
            background-image: repeating-linear-gradient(transparent, transparent 19px, #000 19px, #000 20px);
            text-align: justify;
            font-size: 11px;
            min-height: 40px;
            padding-top: 1px;
        }

        /* Style Khas Lampiran PDF */
        .paper-attachment {
            background: white; 
            width: 210mm; 
            margin: 0 auto 30px; 
            padding: 0;
            box-shadow: 0 4px 20px rgba(0,0,0,0.1); 
            border: 1px solid #ddd;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .paper-attachment canvas {
            max-width: 100%;
            height: auto !important;
            display: block;
        }

        @@media print {
            body { background: white; padding: 0; margin: 0; }
            .paper, .paper-attachment { box-shadow: none; margin: 0; width: 100%; border: none; }
            .paper { padding: 10mm; }
            .top-nav { display: none !important; }
            .paper-attachment-container { margin-top: 0 !important; }
            .paper-attachment-container > div:first-child { display: none !important; } /* Sembunyi tajuk lampiran masa print */
        }

    </style>
</head>
<body>

<div class="top-nav">
    <div class="nav-logo">IARS <span style="font-weight:300;opacity:0.6;">| Result Report</span></div>
    <div class="nav-actions">
        @{
            var userRole = Context.Session.GetString("UserRole");
        }
        @if (userRole == "Admin" || userRole == "KaizenCommittee")
        {
            <a asp-controller="Home" asp-action="AllProposals" class="btn-action btn-back"><i class="bi bi-arrow-left"></i> All Proposals</a>
        }
        else if (userRole == "HOD" || userRole == "Reviewer" || userRole == "FinalApprover")
        {
            <a asp-controller="Home" asp-action="Index" class="btn-action btn-back"><i class="bi bi-arrow-left"></i> Dashboard</a>
        }
        else
        {
            <a asp-action="Index" class="btn-action btn-back"><i class="bi bi-arrow-left"></i> My Proposals</a>
        }
        

        <div class="divider"></div>
        <button onclick="window.print()" class="btn-action btn-print"><i class="bi bi-printer-fill"></i> PRINT</button>
        <button onclick="exportToPDF()" class="btn-action btn-dl">
            <i class="bi bi-download"></i> DOWNLOAD PDF
        </button>
    </div>
</div>

<!-- html2pdf Library -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
    async function exportToPDF() {
        const element = document.querySelector('.paper');
        
        // High-fidelity options for pixel-perfect PDF
        const opt = {
            margin: 0,
            filename: 'Kaizen_Report_@Model.Id' + '.pdf',
            image: { type: 'jpeg', quality: 1.0 },
            html2canvas: { 
                scale: 4, // Maximum sharpness
                useCORS: true, 
                logging: false,
                letterRendering: true,
                allowTaint: true,
                scrollX: 0,
                scrollY: 0,
                onclone: (clonedDoc) => {
                    // Force the paper to look exactly like the preview without browser UI interference
                    const clonedPaper = clonedDoc.querySelector('.paper');
                    if (clonedPaper) {
                        clonedPaper.style.boxShadow = 'none';
                        clonedPaper.style.margin = '0';
                        clonedPaper.style.padding = '8mm'; // Match exactly
                    }
                }
            },
            jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait', compress: true },
            pagebreak: { mode: 'avoid-all' }
        };
        
        try {
            // Use the Worker API for better single-page control
            await html2pdf().set(opt).from(element).save();
        } catch (err) {
            console.error('PDF Export Error:', err);
            alert('PDF Export failed. Please try printing to PDF instead.');
        }
    }
</script>

<div class="paper">
    
    <!-- HEADER V2 (Image Match) -->
    <div class="doc-header">
        <div class="header-logo">
            <img src="/images/logo_isuzum.jpeg" alt="Isuzu" asp-append-version="true" />
        </div>
        <div class="header-title-box">
            <h1>KAIZEN PROPOSAL FORM</h1>
        </div>
        <div class="sig-table-wrapper">
            <div style="font-size: 8px; text-align: right; margin-bottom: 2px; font-weight: 600;">Rev.01/July2025</div>
            <div class="date-label-side">Date</div>
            <table class="sig-table-new">
                <tr>
                    <th style="width: 80px;">Approved</th>
                    <th style="width: 80px;">Checked</th>
                    <th colspan="2">Proposed</th>
                </tr>
                <tr>
                    <td rowspan="3" style="vertical-align: middle;">
                        @if (Model.Status == "FinalApproved" || Model.Status == "Released")
                        {
                            <div class="mini-stamp">
                                <div class="stamp-name">@(Model.FinalApprover?.Name?.Split(' ')[0] ?? "APPROVER")</div>
                                <div class="stamp-center">@(GetDeptAbbr(Model.FinalApprover?.Department))<br/>IHMSB</div>
                                <div class="stamp-date">@Model.ApprovedAt?.ToString("dd/MM/yy")</div>
                            </div>
                        }
                    </td>
                    <td rowspan="3" style="vertical-align: middle;">
                        @if (Model.Status != "Pending" && Model.Status != "UnderReview")
                        {
                            <div class="mini-stamp" style="@(Model.Status == "HODRejected" ? "border-color:#666;color:#666;" : "")">
                                <div class="stamp-name">@(Model.Reviewer?.Name?.Split(' ')[0] ?? "REVIEWER")</div>
                                <div class="stamp-center">@(GetDeptAbbr(Model.Reviewer?.Department))<br/>IHMSB</div>
                                <div class="stamp-date">@Model.ReviewedAt?.ToString("dd/MM/yy")</div>
                            </div>
                        }
                    </td>
                    <td class="label-col">Name</td>
                    <td class="content-col" style="font-weight:800; text-transform:uppercase;">@(Model.Employee?.Name?.ToUpper() ?? "")</td>
                </tr>
                <tr>
                    <td class="label-col">Emp No.</td>
                    <td class="content-col" style="font-weight: 800;">@Model.EmployeeID</td>
                </tr>
                <tr>
                    <td class="label-col">Dept.</td>
                    <td class="content-col" style="font-weight:800;">@(GetDeptAbbr(Model.Employee?.Department).ToUpper())</td>
                </tr>
                <tr class="date-row">
                    <td>@(Model.ApprovedAt?.ToString("dd/MM/yy") ?? "")</td>
                    <td>@(Model.ReviewedAt?.ToString("dd/MM/yy") ?? "")</td>
                    <td colspan="2">@(Model.CreatedAt.ToString("dd/MM/yy"))</td>
                </tr>
            </table>
        </div>
    </div>

    <!-- IMPACT CATEGORIES (Large Checkboxes) -->
    <div style="padding: 0 10px; margin-bottom: 12px; margin-top: 8px;">
        <div class="report-impact-grid">
            <div class="report-impact-item"><div class="box-check">@(Model.IsSafety ? "✔" : "")</div> <span>Safety</span></div>
            <div class="report-impact-item"><div class="box-check">@(Model.IsQuality ? "✔" : "")</div> <span>Quality</span></div>
            <div class="report-impact-item"><div class="box-check">@(Model.IsDelivery ? "✔" : "")</div> <span>Delivery</span></div>
            <div class="report-impact-item"><div class="box-check">@(Model.IsCost ? "✔" : "")</div> <span>Cost</span></div>
            <div class="report-impact-item"><div class="box-check">@(Model.IsFiveS ? "✔" : "")</div> <span>5S</span></div>
            <div class="report-impact-item"><div class="box-check">@(Model.IsDigital ? "✔" : "")</div> <span>Digital</span></div>
        </div>
        
        <div style="display: flex; align-items: center; margin-top: 8px;">
            <span style="font-size: 11px; font-weight: normal; color: #333; width: 85px; flex-shrink: 0;">ISUZU ID </span>
            <div style="display: flex; flex: 1; justify-content: space-between;">
                <div class="report-impact-item" style="flex-direction: row; gap: 10px;">
                    <div class="box-check">@(Model.IsSatisfaction ? "✔" : "")</div> 
                    <div style="display: flex; flex-direction: column; line-height: 1.1;">
                        <span>Satisfaction</span>
                        <span class="isuzu-id-badge" style="background:#3498db; width: fit-content;">No.1</span>
                    </div>
                </div>
                <div class="report-impact-item" style="flex-direction: row; gap: 10px;">
                    <div class="box-check">@(Model.IsSustainability ? "✔" : "")</div> 
                    <div style="display: flex; flex-direction: column; line-height: 1.1;">
                        <span>Sustainability</span>
                        <span class="isuzu-id-badge" style="background:#449d26; width: fit-content;">No.1</span>
                    </div>
                </div>
                <div class="report-impact-item" style="flex-direction: row; gap: 10px;">
                    <div class="box-check">@(Model.IsEngagement ? "✔" : "")</div> 
                    <div style="display: flex; flex-direction: column; line-height: 1.1;">
                        <span>Engagement</span>
                        <span class="isuzu-id-badge" style="background:#c08d0b; width: fit-content;">No.1</span>
                    </div>
                </div>
                <div class="report-impact-item" style="flex-direction: row; gap: 10px;">
                    <div class="box-check">@(Model.IsSocialImpact ? "✔" : "")</div> 
                    <div style="display: flex; flex-direction: column; line-height: 1.1;">
                        <span>Social Impact</span>
                        <span class="isuzu-id-badge" style="background:#e67e22; width: fit-content;">No.1</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- TITLE & PURPOSE (REFINED FOR SPACE) -->
    <div style="margin-top: 0; margin-bottom: 8px; padding: 0 5px;">
        <div style="display: flex; align-items: flex-start; margin-bottom: 5px;">
            <div style="font-weight: 800; font-size: 11px; width: 85px; flex-shrink: 0; margin-top: 4px; display: flex; justify-content: space-between; padding-right: 8px;">
                <span>TITLE</span> <span>:</span>
            </div>
            <div class="form-underline" style="flex-grow: 1; font-weight: 800; text-transform: uppercase;">
                @Model.Title
            </div>
        </div>
        <div style="display: flex; align-items: flex-start;">
            <div style="font-weight: 800; font-size: 11px; width: 85px; flex-shrink: 0; margin-top: 4px; display: flex; justify-content: space-between; padding-right: 8px;">
                <span>OBJECTIVE</span> <span>:</span>
            </div>
            <div class="form-underline" style="flex-grow: 1;">
                @Model.Objective
            </div>
        </div>
    </div>

    <!-- BEFORE & AFTER (RESIZED & STYLED) -->
    <style>
        .impact-line { display: flex; align-items: flex-start; margin-bottom: 8px; font-size: 11px; min-height: 42px; }
        .impact-label { width: 70px; font-weight: 600; flex-shrink: 0; margin-top: 4px; }
        .impact-content { 
            flex-grow: 1; 
            line-height: 20px;
            background-image: repeating-linear-gradient(transparent, transparent 19px, #888 19px, #888 20px);
            text-align: justify;
            font-size: 11px;
            min-height: 40px;
            padding-top: 2px;
        }
    </style>

    <div class="comparison-container">
        <!-- Before -->
        <div class="compare-box">
            <div style="font-weight: 800; font-size: 11px; text-align: center; margin-bottom: 5px; border-bottom: 1px solid #000; padding-bottom: 2px;">BEFORE</div>
            <div class="img-container" style="height: 180px; margin-bottom: 8px;">
                @if(!string.IsNullOrEmpty(Model.ImageBeforePath)){ <img src="@Model.ImageBeforePath" /> }
                else { <span class="text-muted small">No Image</span> }
            </div>
            
            @foreach(var lab in new[] { "Safety", "Quality", "Delivery", "Cost", "5S", "Digital" }) {
                <div class="impact-line">
                    <div class="impact-label" style="display: flex; justify-content: space-between; padding-right: 5px;">
                        <span>@lab</span> <span>:</span>
                    </div>
                    <div class="impact-content">@GetImpactValue(Model.CurrentSituation, lab)</div>
                </div>
            }
        </div>

        <!-- Arrow Space -->
        <div class="arrow-space">
            <div style="width: 30px; height: 20px; background: #00ff00; clip-path: polygon(0% 20%, 60% 20%, 60% 0%, 100% 50%, 60% 100%, 60% 80%, 0% 80%); border: 1px solid #000;"></div>
        </div>

        <!-- After -->
        <div class="compare-box">
            <div style="font-weight: 800; font-size: 11px; text-align: center; margin-bottom: 5px; border-bottom: 1px solid #000; padding-bottom: 2px;">AFTER</div>
            <div class="img-container" style="height: 180px; margin-bottom: 8px;">
                @if(!string.IsNullOrEmpty(Model.ImageAfterPath)){ <img src="@Model.ImageAfterPath" /> }
                else { <span class="text-muted small">No Image</span> }
            </div>

            @foreach(var lab in new[] { "Safety", "Quality", "Delivery", "Cost", "5S", "Digital" }) {
                <div class="impact-line">
                    <div class="impact-label" style="display: flex; justify-content: space-between; padding-right: 5px;">
                        <span>@lab</span> <span>:</span>
                    </div>
                    <div class="impact-content">@GetImpactValue(Model.ImprovementIdea, lab)</div>
                </div>
            }
