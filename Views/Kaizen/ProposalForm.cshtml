<!-- SECTION LAMPIRAN: RENDERING PDF TANPA IFRAME -->
@if (!string.IsNullOrEmpty(Model.AttachmentPath))
{
        <div id="pdf-viewer-container" style="display: flex; flex-direction: column; align-items: center; gap: 20px; margin-top: 50px;">
             <!-- Renders PDF pages directly -->
             <div id="pdf-loader" style="color: white; padding: 40px; text-align: center;">
                 <div class="spinner-border text-light" role="status"></div>
             </div>
        </div>


    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <script>
        const url = '@Url.Content(Model.AttachmentPath)';
        const container = document.getElementById('pdf-viewer-container');
        const loader = document.getElementById('pdf-loader');

        // Fix: Ensure we use the correct global object and check if defined
        const pdfjsLib = window['pdfjs-dist/build/pdf'] || window.pdfjsLib;

        if (pdfjsLib) {
            pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
        }

        async function renderPDF() {
            if (!pdfjsLib) {
                loader.innerHTML = '<div class="alert alert-danger">PDF.js library failed to load.</div>';
                return;
            }

            try {
                const loadingTask = pdfjsLib.getDocument(url);
                const pdf = await loadingTask.promise;
                
                loader.style.display = 'none';

                for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
                    const page = await pdf.getPage(pageNum);
                    const viewport = page.getViewport({ scale: 1.5 });
                    
                    const div = document.createElement('div');
                    div.className = 'paper-attachment';
                    
                    const canvas = document.createElement('canvas');
                    const context = canvas.getContext('2d');
                    canvas.height = viewport.height;
                    canvas.width = viewport.width;
                    canvas.style.width = '100%';
                    canvas.style.height = 'auto';

                    div.appendChild(canvas);
                    container.appendChild(div);

                    const renderContext = {
                        canvasContext: context,
                        viewport: viewport
                    };
                    await page.render(renderContext).promise;
                }
            } catch (err) {
                console.error(err);
                loader.innerHTML = `<div class="alert alert-danger">Error loading PDF: ${err.message}</div>`;
            }
        }

        renderPDF();
    </script>
}

